@using Models
@model Models.Teacher
@{
    string startDate = Model.StartDate.Year > 1 ? Model.StartDate.ToString("yyyy-MM-dd") : "";
    bool creating = ViewBag.Action == "Create";
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <fieldset>
        <legend>Prénom</legend>
        <input id="FirstName" name="FirstName" class="form-control"
               placeholder="Prénom" value="@Model.FirstName"
               required RequireMessage="Veuillez entrer un prénom" />
    </fieldset>

    <fieldset>
        <legend>Nom</legend>
        <input id="LastName" name="LastName" class="form-control"
               placeholder="Nom" value="@Model.LastName"
               required RequireMessage="Veuillez entrer un nom" />
    </fieldset>

    <fieldset>
        <legend>Date d'embauche</legend>
        <input id="StartDate" name="StartDate" class="form-control datepicker"
               placeholder="Date d'embauche" value="@startDate" />
    </fieldset>

    <fieldset>
        <legend>Téléphone</legend>
        <input id="Phone" name="Phone" class="form-control phoneExt"
               placeholder="(999) 999-9999 poste 99999" value="@Model.Phone" />
    </fieldset>

    <fieldset>
        <legend>Courriel</legend>
        <input id="Email" name="Email" class="form-control"
               placeholder="Courriel" value="@Model.Email" />
    </fieldset>

    if (!creating)
    {
        <details open>
            <summary>@NextSession.Caption</summary>
            @* Widget de sélection de cours pour la prochaine session *@
            @Helper.SelectionLists("selectedCoursesId",
                (SelectList)ViewBag.Allocations,
                (SelectList)ViewBag.Courses)
        </details>
    }

    <input id="submit" type="submit" value="Enregistrer" class="btn btn-primary" >
}