@model Models.Course

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <fieldset>
        <legend>Code</legend>
        <input id="Code" name="Code" class="form-control"
               placeholder="Code" value="@Model.Code"
               required RequireMessage="Veuillez entrer un code" />
    </fieldset>

    <fieldset>
        <legend>Titre</legend>
        <input id="Title" name="Title" class="form-control"
               placeholder="Titre" value="@Model.Title"
               required RequireMessage="Veuillez entrer un titre" />
    </fieldset>

    <fieldset>
        <legend>Session</legend>
        <input id="Session" name="Session" type="number" class="form-control"
               placeholder="Session (1-6)" value="@Model.Session"
               required RequireMessage="Veuillez entrer une session" />
    </fieldset>

    <input id="submit" type="submit" value="Enregistrer" class="btn btn-primary">
}